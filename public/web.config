<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <!-- Bloqueia acesso a arquivos sensíveis no public/ -->
        <security>
            <requestFiltering>
                <hiddenSegments>
                    <add segment=".env" />
                    <add segment=".git" />
                    <add segment=".htaccess" />
                </hiddenSegments>
            </requestFiltering>
        </security>
    </system.webServer>
</configuration>
