<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- Static files in public/ root (favicon, manifest, icons, etc.) -->
                <rule name="Public Static Files" stopProcessing="true">
                    <match url="^(favicon\.ico|fav\.png|favdark\.png|logonome\.png|logonomedark\.png|manifest\.json|robots\.txt|icons/.+|sw\.js)$" />
                    <action type="Rewrite" url="public/{R:1}" />
                </rule>
                <!-- Vite build assets — rewrite to public/build/ and let static file handler serve them -->
                <rule name="Vite Assets" stopProcessing="true">
                    <match url="^(build/.+)$" />
                    <action type="Rewrite" url="public/{R:1}" />
                </rule>
                <!-- Docs-IA: arquivos .md estáticos em /docs-ai/ -->
                <rule name="Docs AI Static" stopProcessing="true">
                    <match url="^docs-ai/(.+)$" />
                    <action type="Rewrite" url="public/docs-ai/{R:1}" />
                </rule>
                <!-- SPA: /docs → Laravel (even though docs/ is a real directory) -->
                <rule name="Docs SPA" stopProcessing="true">
                    <match url="^docs" />
                    <action type="Rewrite" url="public/index.php" appendQueryString="true" />
                </rule>
                <!-- Laravel SPA — catch all non-file, non-directory requests -->
                <rule name="Laravel" stopProcessing="true">
                    <match url="^(.*)$" ignoreCase="false" />
                    <conditions logicalGrouping="MatchAll">
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="public/index.php" appendQueryString="true" />
                </rule>
            </rules>
        </rewrite>
        <defaultDocument>
            <files>
                <add value="public\index.php" />
            </files>
        </defaultDocument>
        <security>
            <requestFiltering>
                <denyUrlSequences>
                    <add sequence=".." />
                    <add sequence=".env" />
                    <add sequence=".git" />
                </denyUrlSequences>
                <!-- Bloqueia acesso HTTP direto às pastas do framework e arquivos -->
                <!-- sensíveis. Necessário porque o site aponta para a raiz do -->
                <!-- projeto (e não para /public). Nenhum desses segmentos é usado -->
                <!-- por rotas da API nem pelo SPA (assets ficam em /build). -->
                <hiddenSegments>
                    <add segment="app" />
                    <add segment="bootstrap" />
                    <add segment="config" />
                    <add segment="database" />
                    <add segment="resources" />
                    <add segment="routes" />
                    <add segment="storage" />
                    <add segment="tests" />
                    <add segment="vendor" />
                    <add segment="node_modules" />
                    <add segment="composer.json" />
                    <add segment="composer.lock" />
                    <add segment="package.json" />
                    <add segment="package-lock.json" />
                    <add segment="artisan" />
                    <add segment="phpunit.xml" />
                    <add segment="README.md" />
                </hiddenSegments>
            </requestFiltering>
        </security>
    </system.webServer>
</configuration>
